<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <link name="base_footprint" />
  <link name="base_link">
    <visual>
      <geometry><box size="0.37 0.26 0.072"/></geometry>
      <material name="orange"></material>
    </visual>
    <collision>
      <geometry><box size="0.37 0.26 0.072"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.0182" ixy="0.0" ixz="0.0"
                             iyy="0.0355" iyz="0.0"
                                          izz="0.0511"/>
    </inertial>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.16" rpy="0 0 0" />
  </joint>


  <!-- FRONT LEFT WHEEL -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000111" ixy="0.0" ixz="0.0"
                               iyy="0.000195" iyz="0.0"
                                              izz="0.000111"/>
    </inertial>
  </link>
  <joint name="fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.14 0.155 -0.0985" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- FRONT RIGHT WHEEL -->
  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000111" ixy="0.0" ixz="0.0"
                               iyy="0.000195" iyz="0.0"
                                              izz="0.000111"/>
    </inertial>
  </link>
  <joint name="fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.14 -0.155 -0.0985" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- REAR LEFT WHEEL -->
  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000111" ixy="0.0" ixz="0.0"
                               iyy="0.000195" iyz="0.0"
                                              izz="0.000111"/>
    </inertial>
  </link>
  <joint name="rl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.14 0.155 -0.0985" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- REAR RIGHT WHEEL -->
  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder length="0.04" radius="0.0625"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000111" ixy="0.0" ixz="0.0"
                               iyy="0.000195" iyz="0.0"
                                              izz="0.000111"/>
    </inertial>
  </link>
  <joint name="rr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.14 -0.155 -0.0985" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- IMU link -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- Fixed to base_link at center -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>





  <!-- Contact surface physics -->
  <gazebo reference="front_left_wheel">
    <material>Gazebo/White</material>
    <mu1>1.5</mu1>
    <mu2>0.4</mu2>
    <kp>1e8</kp>
    <kd>1.0</kd>
    <minDepth>0.01</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
    <implicitSpringDamper>true</implicitSpringDamper>
</gazebo>

  <gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>0.4</mu2>
    <kp>1e8</kp>
    <kd>1.0</kd>
    <minDepth>0.01</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
    <implicitSpringDamper>true</implicitSpringDamper>
</gazebo>

  <gazebo reference="rear_left_wheel">
    <material>Gazebo/White</material>
    <mu1>1.5</mu1>
    <mu2>0.4</mu2>
    <kp>1e8</kp>
    <kd>1.0</kd>
    <minDepth>0.01</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
    <implicitSpringDamper>true</implicitSpringDamper>
</gazebo>

  <gazebo reference="rear_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.5</mu1>
    <mu2>0.4</mu2>
    <kp>1e8</kp>
    <kd>1.0</kd>
    <minDepth>0.01</minDepth>
    <maxVel>0.01</maxVel>
    <fdir1>1 0 0</fdir1>
    <implicitSpringDamper>true</implicitSpringDamper>
</gazebo>

</robot>